{
    "name": "coding9/shopware-agent-ready",
    "description": "Make your Shopware 6 store agent-ready: Link headers, Markdown negotiation, Content Signals, well-known endpoints (API catalog, OAuth/OIDC, MCP, A2A, Agent Skills) and WebMCP.",
    "type": "shopware-platform-plugin",
    "license": "MIT",
    "version": "0.0.2",
    "keywords": [
        "shopware",
        "shopware6",
        "agent",
        "ai",
        "mcp",
        "a2a",
        "webmcp",
        "rfc8288",
        "rfc9727",
        "well-known"
    ],
    "authors": [
        {
            "name": "coding9 GmbH",
            "homepage": "https://coding9.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "shopware/core": "~6.7.0",
        "shopware/storefront": "~6.7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.12",
        "shopware/dev-tools": "*",
        "symfony/phpunit-bridge": "^7.0"
    },
    "extra": {
        "shopware-plugin-class": "Coding9\\AgentReady\\Coding9AgentReady",
        "label": {
            "de-DE": "Agent Ready",
            "en-GB": "Agent Ready"
        },
        "description": {
            "de-DE": "Macht Ihren Shopware 6 Shop bereit für KI-Agenten: Link Header (RFC 8288), Markdown for Agents, Content Signals, /.well-known Discovery-Endpunkte und WebMCP.",
            "en-GB": "Make your Shopware 6 store ready for AI agents: Link headers (RFC 8288), Markdown for Agents, Content Signals, /.well-known discovery endpoints and WebMCP."
        },
        "manufacturerLink": {
            "de-DE": "https://coding9.com",
            "en-GB": "https://coding9.com"
        },
        "supportLink": {
            "de-DE": "https://github.com/coding9gmbh/shopware-agent-ready",
            "en-GB": "https://github.com/coding9gmbh/shopware-agent-ready"
        },
        "plugin-icon": "src/Resources/config/plugin.png"
    },
    "autoload": {
        "psr-4": {
            "Coding9\\AgentReady\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Coding9\\AgentReady\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse"
    }
}
