<?xml version="1.0" encoding="UTF-8" ?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/shopware/shopware/trunk/src/Core/System/SystemConfig/Schema/config.xsd">

    <card>
        <title>Link headers (RFC 8288)</title>
        <title lang="de-DE">Link Header (RFC 8288)</title>

        <input-field type="bool">
            <name>enableLinkHeaders</name>
            <label>Enable Link response headers on the homepage</label>
            <label lang="de-DE">Link Response-Header auf der Startseite aktivieren</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="text">
            <name>serviceDocPath</name>
            <label>Path to API documentation (rel="service-doc"). Defaults to the Shopware Store API OpenAPI spec.</label>
            <label lang="de-DE">Pfad zur API-Dokumentation (rel="service-doc"). Standard: Shopware Store API OpenAPI-Spezifikation.</label>
            <defaultValue>/store-api/_info/openapi3.json</defaultValue>
        </input-field>
    </card>

    <card>
        <title>Markdown for Agents</title>
        <title lang="de-DE">Markdown für Agenten</title>

        <input-field type="bool">
            <name>enableMarkdownNegotiation</name>
            <label>Return markdown when Accept: text/markdown is requested</label>
            <label lang="de-DE">Markdown ausliefern, wenn Accept: text/markdown angefragt wird</label>
            <defaultValue>true</defaultValue>
        </input-field>
    </card>

    <card>
        <title>Content Signals (robots.txt)</title>
        <title lang="de-DE">Content Signals (robots.txt)</title>

        <input-field type="bool">
            <name>enableContentSignals</name>
            <label>Add Content-Signal directives to robots.txt</label>
            <label lang="de-DE">Content-Signal Direktiven in robots.txt hinzufügen</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="single-select">
            <name>contentSignalAiTrain</name>
            <label>ai-train</label>
            <defaultValue>no</defaultValue>
            <options>
                <option><id>yes</id><name>yes</name></option>
                <option><id>no</id><name>no</name></option>
            </options>
        </input-field>

        <input-field type="single-select">
            <name>contentSignalSearch</name>
            <label>search</label>
            <defaultValue>yes</defaultValue>
            <options>
                <option><id>yes</id><name>yes</name></option>
                <option><id>no</id><name>no</name></option>
            </options>
        </input-field>

        <input-field type="single-select">
            <name>contentSignalAiInput</name>
            <label>ai-input</label>
            <defaultValue>no</defaultValue>
            <options>
                <option><id>yes</id><name>yes</name></option>
                <option><id>no</id><name>no</name></option>
            </options>
        </input-field>
    </card>

    <card>
        <title>Well-Known endpoints</title>
        <title lang="de-DE">Well-Known Endpunkte</title>

        <input-field type="bool">
            <name>enableApiCatalog</name>
            <label>Publish /.well-known/api-catalog (RFC 9727)</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="bool">
            <name>enableOAuthDiscovery</name>
            <label>Publish /.well-known/oauth-authorization-server (RFC 8414)</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="bool">
            <name>enableOAuthProtectedResource</name>
            <label>Publish /.well-known/oauth-protected-resource (RFC 9728)</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="bool">
            <name>enableMcpServerCard</name>
            <label>Publish /.well-known/mcp/server-card.json (SEP-1649)</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="text">
            <name>mcpServerEndpoint</name>
            <label>MCP server endpoint URL (leave empty to omit)</label>
            <label lang="de-DE">MCP Server Endpunkt URL (leer = weglassen)</label>
        </input-field>

        <input-field type="bool">
            <name>enableA2aAgentCard</name>
            <label>Publish /.well-known/agent-card.json (A2A)</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="text">
            <name>a2aAgentName</name>
            <label>A2A agent name</label>
            <defaultValue>Shopware Storefront Agent</defaultValue>
        </input-field>

        <input-field type="textarea">
            <name>a2aAgentDescription</name>
            <label>A2A agent description</label>
            <defaultValue>Discover products, place orders and manage the shopping cart on this Shopware 6 storefront.</defaultValue>
        </input-field>

        <input-field type="bool">
            <name>enableAgentSkillsIndex</name>
            <label>Publish /.well-known/agent-skills/index.json</label>
            <defaultValue>true</defaultValue>
        </input-field>
    </card>

    <card>
        <title>llms.txt</title>
        <title lang="de-DE">llms.txt</title>

        <input-field type="bool">
            <name>enableLlmsTxt</name>
            <label>Publish /llms.txt and /llms-full.txt</label>
            <label lang="de-DE">/llms.txt und /llms-full.txt veröffentlichen</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="text">
            <name>siteName</name>
            <label>Site name (defaults to the sales channel hostname)</label>
            <label lang="de-DE">Shop-Name (Standard: Hostname des Sales Channels)</label>
        </input-field>

        <input-field type="textarea">
            <name>siteSummary</name>
            <label>Short summary used as the llms.txt blockquote</label>
            <label lang="de-DE">Kurzbeschreibung für das llms.txt Blockquote</label>
            <defaultValue>Shopware 6 storefront with AI-agent discovery enabled.</defaultValue>
        </input-field>
    </card>

    <card>
        <title>WebMCP</title>
        <title lang="de-DE">WebMCP</title>

        <input-field type="bool">
            <name>enableWebMcp</name>
            <label>Inject navigator.modelContext.provideContext() tools on storefront pages</label>
            <label lang="de-DE">navigator.modelContext.provideContext() Tools im Storefront einbinden</label>
            <defaultValue>true</defaultValue>
        </input-field>
    </card>

    <card>
        <title>Agent runtime endpoints</title>
        <title lang="de-DE">Agent-Runtime-Endpunkte</title>

        <input-field type="bool">
            <name>enableMcpServer</name>
            <label>Host the MCP JSON-RPC server at /mcp</label>
            <label lang="de-DE">MCP-JSON-RPC-Server unter /mcp betreiben</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="bool">
            <name>enableA2aServer</name>
            <label>Host the A2A JSON-RPC server at /a2a</label>
            <label lang="de-DE">A2A-JSON-RPC-Server unter /a2a betreiben</label>
            <defaultValue>true</defaultValue>
        </input-field>
    </card>

    <card>
        <title>Skill toggles</title>
        <title lang="de-DE">Skill-Schalter</title>

        <input-field type="bool">
            <name>enableSkillSearchProducts</name>
            <label>Expose skill: search-products</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="bool">
            <name>enableSkillGetProduct</name>
            <label>Expose skill: get-product</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="bool">
            <name>enableSkillCreateContext</name>
            <label>Expose skill: create-context</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="bool">
            <name>enableSkillGetCart</name>
            <label>Expose skill: get-cart</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="bool">
            <name>enableSkillManageCart</name>
            <label>Expose skill: manage-cart</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="bool">
            <name>enableSkillCustomerLogin</name>
            <label>Expose skill: customer-login (passwords flow through the agent host — disable if not needed)</label>
            <label lang="de-DE">Skill freischalten: customer-login (Passwörter fließen über den Agent-Host — deaktivieren wenn nicht benötigt)</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="bool">
            <name>enableSkillCustomerLogout</name>
            <label>Expose skill: customer-logout</label>
            <defaultValue>true</defaultValue>
        </input-field>

        <input-field type="bool">
            <name>enableSkillPlaceOrder</name>
            <label>Expose skill: place-order (commits real orders — review limits below first)</label>
            <label lang="de-DE">Skill freischalten: place-order (löst echte Bestellungen aus — Limits unten prüfen)</label>
            <defaultValue>true</defaultValue>
        </input-field>
    </card>

    <card>
        <title>Hardening</title>
        <title lang="de-DE">Härtung</title>

        <input-field type="text">
            <name>placeOrderMaxAmount</name>
            <label>Maximum order amount the place-order skill is allowed to commit (in main currency units, e.g. 250.0 = 250 EUR/USD/...). Empty or 0 = unlimited.</label>
            <label lang="de-DE">Maximaler Bestellwert für den place-order-Skill (in Haupt-Währungseinheit, z.B. 250.0 = 250 EUR). Leer oder 0 = kein Limit.</label>
        </input-field>

        <input-field type="textarea">
            <name>corsAllowedOrigins</name>
            <label>CORS allow-list for /mcp and /a2a (comma- or newline-separated origins, e.g. https://claude.ai). Empty = no CORS header (safest, server-side agent hosts don't need it). Use "*" only for development.</label>
            <label lang="de-DE">CORS-Allowlist für /mcp und /a2a (kommagetrennt oder eine Origin pro Zeile, z.B. https://claude.ai). Leer = kein CORS-Header (sicherste Einstellung, server-seitige Agent-Hosts brauchen keine). "*" nur für die Entwicklung.</label>
        </input-field>
    </card>
</config>
