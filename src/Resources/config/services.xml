<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services
                               http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <!-- Services -->
        <service id="Coding9\AgentReady\Service\HtmlToMarkdownConverter"/>
        <service id="Coding9\AgentReady\Service\JsonLdExtractor"/>
        <service id="Coding9\AgentReady\Service\ProductMarkdownRenderer"/>

        <service id="Coding9\AgentReady\Service\SystemConfigReader">
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
        </service>

        <service id="Coding9\AgentReady\Service\ConfigReader" alias="Coding9\AgentReady\Service\SystemConfigReader"/>

        <service id="Coding9\AgentReady\Service\AgentConfig">
            <argument type="service" id="Coding9\AgentReady\Service\ConfigReader"/>
        </service>

        <service id="Coding9\AgentReady\Skill\SkillRegistry"/>

        <service id="Coding9\AgentReady\StoreApi\KernelStoreApiClient">
            <argument type="service" id="http_kernel"/>
        </service>
        <service id="Coding9\AgentReady\StoreApi\HttpStoreApiClient">
            <argument type="service" id="Symfony\Contracts\HttpClient\HttpClientInterface"/>
            <argument type="service" id="request_stack"/>
        </service>
        <!-- Default to the real-HTTP client. The kernel sub-request client
             is kept around for environments where outbound self-loopback
             is impossible, but it cannot persist cart state across calls. -->
        <service id="Coding9\AgentReady\StoreApi\StoreApiClient" alias="Coding9\AgentReady\StoreApi\HttpStoreApiClient"/>

        <service id="Coding9\AgentReady\StoreApi\RepositorySalesChannelKeyResolver">
            <argument type="service" id="sales_channel.repository"/>
        </service>
        <service id="Coding9\AgentReady\StoreApi\SalesChannelKeyResolver" alias="Coding9\AgentReady\StoreApi\RepositorySalesChannelKeyResolver"/>

        <service id="Coding9\AgentReady\Skill\SkillExecutor">
            <argument type="service" id="Coding9\AgentReady\StoreApi\StoreApiClient"/>
            <argument type="service" id="Coding9\AgentReady\StoreApi\SalesChannelKeyResolver"/>
            <argument type="service" id="Coding9\AgentReady\Service\AgentConfig"/>
        </service>

        <service id="Coding9\AgentReady\Mcp\McpServer">
            <argument type="service" id="Coding9\AgentReady\Skill\SkillRegistry"/>
            <argument type="service" id="Coding9\AgentReady\Skill\SkillExecutor"/>
            <argument type="service" id="Coding9\AgentReady\Service\AgentConfig"/>
        </service>

        <service id="Coding9\AgentReady\A2a\A2aServer">
            <argument type="service" id="Coding9\AgentReady\Skill\SkillRegistry"/>
            <argument type="service" id="Coding9\AgentReady\Skill\SkillExecutor"/>
            <argument type="service" id="Coding9\AgentReady\Service\AgentConfig"/>
        </service>

        <!-- Subscribers -->
        <service id="Coding9\AgentReady\Subscriber\LinkHeaderSubscriber">
            <argument type="service" id="Coding9\AgentReady\Service\AgentConfig"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Coding9\AgentReady\Subscriber\MarkdownNegotiationSubscriber">
            <argument type="service" id="Coding9\AgentReady\Service\AgentConfig"/>
            <argument type="service" id="Coding9\AgentReady\Service\HtmlToMarkdownConverter"/>
            <argument type="service" id="Coding9\AgentReady\Service\JsonLdExtractor"/>
            <argument type="service" id="Coding9\AgentReady\Service\ProductMarkdownRenderer"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Coding9\AgentReady\Subscriber\RobotsTxtSubscriber">
            <argument type="service" id="Coding9\AgentReady\Service\AgentConfig"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <!-- Exempt MCP/A2A skill sub-requests from Shopware's RouteScopeListener.
             See CrossScopeSubRequestWhitelist for the reasoning. -->
        <service id="Coding9\AgentReady\Framework\Routing\CrossScopeSubRequestWhitelist">
            <argument type="service" id="request_stack"/>
            <tag name="shopware.route_scope_whitelist"/>
        </service>

        <!-- Controllers -->
        <service id="Coding9\AgentReady\Controller\WellKnownController" public="true">
            <argument type="service" id="Coding9\AgentReady\Service\AgentConfig"/>
            <argument type="service" id="Coding9\AgentReady\Skill\SkillRegistry"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

        <service id="Coding9\AgentReady\Controller\McpController" public="true">
            <argument type="service" id="Coding9\AgentReady\Service\AgentConfig"/>
            <argument type="service" id="Coding9\AgentReady\Mcp\McpServer"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

        <service id="Coding9\AgentReady\Controller\A2aController" public="true">
            <argument type="service" id="Coding9\AgentReady\Service\AgentConfig"/>
            <argument type="service" id="Coding9\AgentReady\A2a\A2aServer"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

        <service id="Coding9\AgentReady\Controller\RobotsTxtController" public="true">
            <argument type="service" id="Coding9\AgentReady\Service\AgentConfig"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

        <service id="Coding9\AgentReady\Controller\LlmsTxtController" public="true">
            <argument type="service" id="Coding9\AgentReady\Service\AgentConfig"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>
    </services>
</container>
