<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services
                               http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <!-- Services -->
        <service id="Coding9\AgentReady\Service\HtmlToMarkdownConverter"/>

        <service id="Coding9\AgentReady\Service\SystemConfigReader">
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
        </service>

        <service id="Coding9\AgentReady\Service\ConfigReader" alias="Coding9\AgentReady\Service\SystemConfigReader"/>

        <service id="Coding9\AgentReady\Service\AgentConfig">
            <argument type="service" id="Coding9\AgentReady\Service\ConfigReader"/>
        </service>

        <!-- Subscribers -->
        <service id="Coding9\AgentReady\Subscriber\LinkHeaderSubscriber">
            <argument type="service" id="Coding9\AgentReady\Service\AgentConfig"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Coding9\AgentReady\Subscriber\MarkdownNegotiationSubscriber">
            <argument type="service" id="Coding9\AgentReady\Service\AgentConfig"/>
            <argument type="service" id="Coding9\AgentReady\Service\HtmlToMarkdownConverter"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <!-- Controllers -->
        <service id="Coding9\AgentReady\Controller\WellKnownController" public="true">
            <argument type="service" id="Coding9\AgentReady\Service\AgentConfig"/>
            <argument type="service" id="router"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

        <service id="Coding9\AgentReady\Controller\RobotsTxtController" public="true">
            <argument type="service" id="Coding9\AgentReady\Service\AgentConfig"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>
    </services>
</container>
