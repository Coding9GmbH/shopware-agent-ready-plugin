{% sw_extends '@Storefront/storefront/base.html.twig' %}

{% block base_body_inner %}
    {{ parent() }}

    {# Resolve the toggle per sales-channel so multi-channel shops can opt in or out individually. #}
    {% set _coding9_sc_id = context.salesChannel.id ?? null %}
    {% if config('Coding9AgentReady.config.enableWebMcp', _coding9_sc_id) %}
        <script type="text/javascript" data-coding9-agent-ready="webmcp">
            (function () {
                if (typeof navigator === 'undefined' || !('modelContext' in navigator)) {
                    return;
                }

                try {
                    navigator.modelContext.provideContext({
                        tools: [
                            {
                                name: 'search_products',
                                description: 'Search products in this Shopware storefront.',
                                inputSchema: {
                                    type: 'object',
                                    properties: {
                                        query: { type: 'string', description: 'Search term' }
                                    },
                                    required: ['query']
                                },
                                execute: async function (input) {
                                    var q = encodeURIComponent(String((input && input.query) || ''));
                                    window.location.assign('/search?search=' + q);
                                    return { ok: true, redirected: true };
                                }
                            },
                            {
                                name: 'open_cart',
                                description: 'Open the shopping cart page.',
                                inputSchema: { type: 'object', properties: {} },
                                execute: async function () {
                                    window.location.assign('/checkout/cart');
                                    return { ok: true, redirected: true };
                                }
                            },
                            {
                                name: 'open_account',
                                description: 'Navigate to the customer account page.',
                                inputSchema: { type: 'object', properties: {} },
                                execute: async function () {
                                    window.location.assign('/account');
                                    return { ok: true, redirected: true };
                                }
                            },
                            {
                                name: 'open_checkout',
                                description: 'Navigate to the checkout page.',
                                inputSchema: { type: 'object', properties: {} },
                                execute: async function () {
                                    window.location.assign('/checkout/confirm');
                                    return { ok: true, redirected: true };
                                }
                            }
                        ]
                    });
                } catch (e) {
                    if (window.console && console.warn) {
                        console.warn('[coding9/agent-ready] WebMCP setup failed', e);
                    }
                }
            })();
        </script>
    {% endif %}
{% endblock %}
